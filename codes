import java.util.Scanner;

public class SumOfSubsets {

    static int n;
    static int set[];
    static int target;
    static int subset[];

    static void sumSubset(int index, int currentSum) {

        if (currentSum == target) {
            System.out.print("Subset: ");
            for (int i = 0; i < index; i++)
                if (subset[i] == 1)
                    System.out.print(set[i] + " ");
            System.out.println();
            return;
        }

        if (index == n || currentSum > target)
            return;

        // Include the element
        subset[index] = 1;
        sumSubset(index + 1, currentSum + set[index]);

        // Exclude the element
        subset[index] = 0;
        sumSubset(index + 1, currentSum);
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of elements: ");
        n = sc.nextInt();

        set = new int[n];
        subset = new int[n];

        System.out.println("Enter elements:");
        for (int i = 0; i < n; i++)
            set[i] = sc.nextInt();

        System.out.print("Enter target sum: ");
        target = sc.nextInt();

        sumSubset(0, 0);
    }
}
