import java.util.Scanner;

public class TSP_BB {

    static int n;
    static int[][] cost;
    static boolean[] visited;
    static int minCost = Integer.MAX_VALUE;

    static void tsp(int city, int count, int currCost) {

        if (count == n && cost[city][0] > 0) {
            minCost = Math.min(minCost, currCost + cost[city][0]);
            return;
        }

        for (int i = 0; i < n; i++) {
            if (!visited[i] && cost[city][i] > 0) {

                int tempCost = currCost + cost[city][i];

                if (tempCost < minCost) {
                    visited[i] = true;
                    tsp(i, count + 1, tempCost);
                    visited[i] = false;
                }
            }
        }
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of cities: ");
        n = sc.nextInt();

        cost = new int[n][n];
        visited = new boolean[n];

        System.out.println("Enter cost matrix:");
        for (int i = 0; i < n; i++)
            for (int j = 0; j < n; j++)
                cost[i][j] = sc.nextInt();

        visited[0] = true;
        tsp(0, 1, 0);

        System.out.println("Minimum travelling cost (Branch & Bound): " + minCost);
    }
}
