            {INF, INF, INF, INF, INF, INF, INF, INF, INF, INF, INF, INF}
        };

        int dist[] = new int[n];
        int path[] = new int[n];

        // Initialize
        dist[n - 1] = 0;

        // Compute shortest path
        for (int i = n - 2; i >= 0; i--) {
            dist[i] = INF;
            for (int j = i + 1; j < n; j++) {
                if (cost[i][j] != INF && cost[i][j] + dist[j] < dist[i]) {
                    dist[i] = cost[i][j] + dist[j];
                    path[i] = j;
                }
