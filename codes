import java.util.Scanner;

public class OptimalBST {

    static final int MAX = 20;

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of keys: ");
        int n = sc.nextInt();

        int keys[] = new int[n + 1];
        float p[] = new float[n + 1];
        float q[] = new float[n + 1];
        float w[][] = new float[MAX][MAX];
        float c[][] = new float[MAX][MAX];
        int r[][] = new int[MAX][MAX];

        System.out.println("Enter keys:");
        for (int i = 1; i <= n; i++)
            keys[i] = sc.nextInt();

        System.out.println("Enter successful search probabilities (p):");
        for (int i = 1; i <= n; i++)
            p[i] = sc.nextFloat();

        System.out.println("Enter unsuccessful search probabilities (q):");
        for (int i = 0; i <= n; i++)
            q[i] = sc.nextFloat();

        // Initialization
        for (int i = 0; i <= n; i++) {
            w[i][i] = q[i];
            c[i][i] = 0;
            r[i][i] = 0;
        }

        // Dynamic Programming
        for (int i = 0; i < n; i++) {
            w[i][i + 1] = q[i] + q[i + 1] + p[i + 1];
            c[i][i + 1] = w[i][i + 1];
            r[i][i + 1] = i + 1;
        }

        for (int m = 2; m <= n; m++) {
            for (int i = 0; i <= n - m; i++) {
                int j = i + m;
                w[i][j] = w[i][j - 1] + p[j] + q[j];
                c[i][j] = Float.MAX_VALUE;

                for (int k = i + 1; k <= j; k++) {
                    float cost = c[i][k - 1] + c[k][j];
                    if (cost < c[i][j]) {
                        c[i][j] = cost;
                        r[i][j] = k;
                    }
                }
                c[i][j] += w[i][j];
            }
        }

        // Output
        System.out.println("\nOptimal Binary Search Tree Results:");
        System.out.println("Minimum cost: " + c[0][n]);
        System.out.println("Root of OBST: Key " + keys[r[0][n]]);
    }
}
